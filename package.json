{
  "name": "iobroker.solarforecast",
  "version": "0.5.6",
  "description": "Solar forecast adapter for ioBroker using Open-Meteo",
  "author": {
    "name": "Hagen",
    "email": "no-reply@example.com"
  },
  "contributors": [],
  "homepage": "https://github.com/hag174/ioBroker.solarforecast",
  "license": "MIT",
  "keywords": [
    "solar",
    "forecast",
    "pv",
    "open-meteo"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hag174/ioBroker.solarforecast.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/chai": "^5.2.3",
    "@types/iobroker": "npm:@iobroker/types@^7.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.37",
    "@types/sinon": "^17.0.4",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "chai-as-promised": "^8.0.2",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.3",
    "sinon": "^21.0.0",
    "sinon-chai": "^4.0.1",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "test:ts": "mocha --config test/mocharc.custom.json \"Tests/**/*.test.ts\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "check": "tsc --noEmit",
    "coverage": "c8 mocha --config test/mocharc.custom.json \"Tests/**/*.test.ts\"",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server"
  },
  "c8": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/lib/adapter-config.d.ts"
    ],
    "reporter": [
      "text-summary",
      "html"
    ]
  },
  "bugs": {
    "url": "https://github.com/hag174/ioBroker.solarforecast/issues"
  },
  "readmeFilename": "README.md"
}
